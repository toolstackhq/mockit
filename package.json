{
  "name": "@toolstackhq/mockit",
  "version": "1.0.0",
  "description": "Enterprise REST/gRPC mocking library for banking microservices",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toolstackhq/mockit.git"
  },
  "homepage": "https://github.com/toolstackhq/mockit",
  "bugs": {
    "url": "https://github.com/toolstackhq/mockit/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mockit": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "mock",
    "rest",
    "api",
    "testing",
    "microservices"
  ],
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.5",
    "@vitest/coverage-istanbul": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "json-schema-faker": "^0.6.0",
    "jsonpath-plus": "^10.4.0"
  }
}
